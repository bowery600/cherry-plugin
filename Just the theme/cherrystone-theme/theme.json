{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 2,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": false,
		"layout": {
			"contentSize": "720px",
			"wideSize": "1320px"
		},
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"custom": true,
			"customDuotone": false,
			"palette": [
				{ "slug": "navy-900", "color": "#0B1B2B", "name": "Primary Base Dark" },
				{ "slug": "navy-800", "color": "#0E243A", "name": "Primary Base 800" },
				{ "slug": "navy-700", "color": "#12304C", "name": "Primary Base 700" },
				{ "slug": "navy-600", "color": "#174169", "name": "Primary Base 600" },
				{ "slug": "navy-100", "color": "#EAF0F6", "name": "Cool Gray 100" },
				{ "slug": "navy-50", "color": "#F3F7FA", "name": "Cool Gray 50" },
				{ "slug": "ink", "color": "#0B1B2B", "name": "Ink" },
				{ "slug": "ink-muted", "color": "#56524d", "name": "Ink Muted" },
				{ "slug": "paper", "color": "#fbfaf7", "name": "Paper" },
				{ "slug": "paper-warm", "color": "#f2eee6", "name": "Paper Warm" },
				{ "slug": "surface", "color": "#FFFFFF", "name": "Surface" },
				{ "slug": "line", "color": "#DDE4EB", "name": "Line" },
				{ "slug": "line-soft", "color": "#EBF0F5", "name": "Line Soft" },
				{ "slug": "accent", "color": "#1A5B7A", "name": "Harbor Teal" },
				{ "slug": "accent-ink", "color": "#14455C", "name": "Harbor Teal Ink" },
				{ "slug": "accent-soft", "color": "#E3EEF4", "name": "Accent Soft" },
				{ "slug": "accent-gold", "color": "#E8A365", "name": "Accent Gold" },
				{ "slug": "sea", "color": "#5F8B9C", "name": "Cool Sea" },
				{ "slug": "success", "color": "#2F6F4E", "name": "Success" }
			]
		},
		"typography": {
			"fluid": true,
			"customFontSize": true,
			"lineHeight": true,
			"dropCap": false,
			"fontFamilies": [
				{
					"fontFamily": "'Inter Tight', 'Inter', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Arial, sans-serif",
					"slug": "sans",
					"name": "Inter Tight"
				},
				{
					"fontFamily": "'EB Garamond', Georgia, serif",
					"slug": "serif",
					"name": "EB Garamond"
				},
				{
					"fontFamily": "'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace",
					"slug": "mono",
					"name": "JetBrains Mono"
				}
			],
			"fontSizes": [
				{ "slug": "small", "size": "13px", "name": "Small" },
				{ "slug": "medium", "size": "16px", "name": "Medium" },
				{ "slug": "large", "size": "clamp(18px, 1.5vw, 22px)", "name": "Large" },
				{ "slug": "x-large", "size": "clamp(22px, 2vw, 28px)", "name": "Extra Large" },
				{ "slug": "xx-large", "size": "clamp(36px, 4vw, 56px)", "name": "Display" }
			]
		},
		"spacing": {
			"units": [ "px", "em", "rem", "vw", "vh", "%" ],
			"padding": true,
			"margin": true,
			"blockGap": true,
			"spacingSizes": [
				{ "slug": "20", "size": "16px", "name": "1" },
				{ "slug": "30", "size": "24px", "name": "2" },
				{ "slug": "40", "size": "32px", "name": "3" },
				{ "slug": "50", "size": "48px", "name": "4" },
				{ "slug": "60", "size": "72px", "name": "5" },
				{ "slug": "70", "size": "120px", "name": "6" }
			]
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"blocks": {
			"core/button": {
				"border": { "radius": "999px" }
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--paper)",
			"text": "var(--wp--preset--color--ink)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--sans)",
			"fontSize": "16px",
			"lineHeight": "1.65",
			"fontWeight": "400"
		},
		"elements": {
			"link": {
				"color": { "text": "var(--wp--preset--color--accent-ink)" },
				":hover": { "color": { "text": "var(--wp--preset--color--ink)" } }
			},
			"heading": {
				"color": { "text": "var(--wp--preset--color--ink)" },
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontWeight": "500",
					"letterSpacing": "-0.02em",
					"lineHeight": "1.1"
				}
			},
			"h1": { "typography": { "fontSize": "clamp(48px, 6vw, 88px)", "lineHeight": "1", "letterSpacing": "-0.035em" } },
			"h2": { "typography": { "fontSize": "clamp(36px, 4vw, 56px)", "lineHeight": "1.02", "letterSpacing": "-0.03em" } },
			"h3": { "typography": { "fontSize": "clamp(22px, 2vw, 28px)", "lineHeight": "1.15" } },
			"button": {
				"color": {
					"background": "var(--wp--preset--color--ink)",
					"text": "var(--wp--preset--color--paper)"
				},
				"typography": { "fontWeight": "600", "fontSize": "14px" },
				"border": { "radius": "999px" },
				"spacing": { "padding": { "top": "14px", "bottom": "14px", "left": "22px", "right": "22px" } },
				":hover": { "color": { "background": "var(--wp--preset--color--accent-ink)", "text": "#ffffff" } }
			}
		},
		"blocks": {
			"core/post-title": {
				"typography": { "fontSize": "clamp(48px, 6vw, 88px)", "fontWeight": "500", "letterSpacing": "-0.035em", "lineHeight": "1" }
			},
			"core/site-title": {
				"typography": { "fontSize": "16px", "fontWeight": "600", "letterSpacing": "-0.01em" },
				"color": { "text": "var(--wp--preset--color--ink)" }
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	],
	"customTemplates": [
		{ "name": "page-blank", "title": "Blank Full-Width Canvas", "postTypes": [ "page", "post" ] }
	]
}
