	<!-- Page: Apply -->
	<item>
		<title>Apply</title>
		<link>http://localhost/apply</link>
		<pubDate>Wed, 03 Jun 2026 00:00:00 +0000</pubDate>
		<dc:creator><![CDATA[admin]]></dc:creator>
		<guid isPermaLink="false">http://localhost/?page_id=10003</guid>
		<description></description>
		<content:encoded><![CDATA[<!-- wp:html -->
<section class="page-hero with-graphic">
	<div class="container">
		<span class="eyebrow accent">Apply for capital</span>
		<h1 style="margin-top:24px">Tell us what<br>you're building.</h1>
		<p class="lede">For founders raising in life sciences, software, consumer, industrial tech, healthcare, or fintech. We read every application - even the ones we say no to.</p>
		<div class="page-hero-meta">
			<span><strong>Stage</strong> Pre-seed to Series A</span>
			<span><strong>Geography</strong> New England preferred</span>
			<span><strong>Verticals</strong> 6</span>
		</div>
		<div class="application-progress" data-cherry-progress aria-label="Application readiness 0%">
			<div>
				<span>Application readiness</span>
				<strong data-cherry-progress-value>0%</strong>
			</div>
			<span class="application-progress-track" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0"><span data-cherry-progress-bar style="width:0%"></span></span>
		</div>
	</div>
</section>

<section class="block warm diligence-timeline-section">
	<div class="container">
		<div class="block-head">
			<div>
				<span class="eyebrow accent">Process</span>
				<h2 style="margin-top:24px">The path to capital.</h2>
			</div>
			<p class="lede">We move quickly and respect your time. These are the steps we use as we evaluate your application.</p>
		</div>
		<div class="value-grid">
			<div class="value-card"><span class="num">01 - APPLY</span><h3>Submit the basics.</h3><p>Tell us what you are scaling, your New England roots, and your current round size.</p></div>
			<div class="value-card"><span class="num">02 - SCREEN</span><h3>Meet the committee.</h3><p>A focused screening conversation with members who understand your sector and stage.</p></div>
			<div class="value-card"><span class="num">03 - DILIGENCE</span><h3>Go deeper with members.</h3><p>We review customers, product, metrics, market assumptions, and round structure.</p></div>
			<div class="value-card"><span class="num">04 - PITCH</span><h3>Pitch the room.</h3><p>Present to the Cherrystone membership and move toward individual checks.</p></div>
		</div>
	</div>
</section>
<!-- /wp:html -->

<!-- wp:cherrystone/founder-application-form /-->

<!-- wp:html -->
<section class="footer-cta">
	<div class="container footer-cta-grid">
		<div>
			<span class="eyebrow accent">Get involved</span>
			<h2>Capital. Judgment. <em>Time.</em><br>Where founders need it.</h2>
		</div>
		<div class="footer-cta-cards">
			<a class="footer-cta-card" href="/apply/"><span>FOR FOUNDERS</span><h3>Apply for capital</h3><p>One application, reviewed by our investment committee.</p></a>
			<a class="footer-cta-card" href="/members/"><span>FOR INVESTORS</span><h3>Become a member</h3><p>Join active members investing alongside operators, founders, and former exits.</p></a>
		</div>
	</div>
</section>
<!-- /wp:html -->]]></content:encoded>
