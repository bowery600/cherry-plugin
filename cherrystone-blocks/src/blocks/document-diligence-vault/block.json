{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "cherrystone/document-diligence-vault",
	"version": "1.0.0",
	"title": "Document Diligence Vault",
	"category": "cherrystone-founders",
	"icon": "saved",
	"description": "Secure document list featuring standard templates, guidelines, and bylaws.",
	"textdomain": "cherrystone-blocks",
	"supports": {
		"html": false,
		"align": [ "wide", "full" ]
	},
	"attributes": {
		"eyebrow": {
			"type": "string",
			"default": "RESOURCES & GUIDELINES"
		},
		"heading": {
			"type": "string",
			"default": "Diligence templates."
		},
		"lede": {
			"type": "string",
			"default": "Members and pitching founders can access and download our standard investment materials and evaluation sheets."
		},
		"vaultDocuments": {
			"type": "array",
			"default": [
				{
					"title": "Cherrystone Investment Thesis",
					"type": "PDF",
					"size": "1.2 MB",
					"isLocked": false
				},
				{
					"title": "Founder Diligence Questionnaire",
					"type": "DOCX",
					"size": "450 KB",
					"isLocked": true
				},
				{
					"title": "Standard Term Sheet Outline",
					"type": "XLSX",
					"size": "850 KB",
					"isLocked": true
				}
			]
		}
	}
}
