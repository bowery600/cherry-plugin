{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "cherrystone/founder-application-form",
  "version": "1.0.0",
  "title": "Founder Application Form",
  "category": "cherrystone-founders",
  "icon": "feedback",
  "description": "Founder capital application with a readiness meter that opens a prefilled email on submit.",
  "textdomain": "cherrystone-blocks",
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ]
  },
  "attributes": {
    "heading": {
      "type": "string",
      "default": "Tell us what you're building."
    },
    "submitLabel": {
      "type": "string",
      "default": "Submit application"
    },
    "recipient": {
      "type": "string",
      "default": "info@cherrystoneangelgroup.com"
    },
    "wpformsId": {
      "type": "number",
      "default": 0
    }
  }
}