{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "cherrystone/pitch-night-spotlight",
  "version": "1.0.0",
  "title": "Pitch Night Spotlight",
  "category": "cherrystone-content",
  "icon": "megaphone",
  "description": "countdown timer spotlight for Providence Pitch Nights, featuring dates and rsvp links.",
  "textdomain": "cherrystone-blocks",
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ]
  },
  "attributes": {
    "eyebrow": {
      "type": "string",
      "default": "UPCOMING EVENT"
    },
    "heading": {
      "type": "string",
      "default": "Cherrystone Pitch Night"
    },
    "lede": {
      "type": "string",
      "default": "Join our members in Providence as we review three high-growth startups pitching for investment."
    },
    "eventDate": {
      "type": "string",
      "default": "June 18, 2026 at 6:00 PM"
    },
    "location": {
      "type": "string",
      "default": "Providence Innovation District, RI"
    },
    "ctaText": {
      "type": "string",
      "default": "REGISTER AS GUEST / MEMBER"
    },
    "ctaLink": {
      "type": "string",
      "default": "#register"
    }
  }
}