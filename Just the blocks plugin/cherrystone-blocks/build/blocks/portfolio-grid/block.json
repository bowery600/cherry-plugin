{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "cherrystone/portfolio-grid",
  "version": "1.1.0",
  "title": "Portfolio Grid",
  "category": "cherrystone-core",
  "icon": "portfolio",
  "description": "Portfolio company grid driven by the Portfolio Companies you manage in wp-admin.",
  "textdomain": "cherrystone-blocks",
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ]
  },
  "attributes": {
    "eyebrow": {
      "type": "string",
      "default": "Portfolio"
    },
    "heading": {
      "type": "string",
      "default": "Active Portfolio"
    },
    "lede": {
      "type": "string",
      "default": "From silicon nanotechnology to digital banking to autonomous underwater vehicles. A live snapshot of the active portfolio - full list on the Portfolio page."
    },
    "ctaLabel": {
      "type": "string",
      "default": "See all active companies"
    },
    "ctaUrl": {
      "type": "string",
      "default": "/portfolio"
    },
    "maxItems": {
      "type": "number",
      "default": 0
    },
    "sectorFilter": {
      "type": "string",
      "default": ""
    },
    "statusFilter": {
      "type": "string",
      "default": "Active"
    },
    "displayMode": {
      "type": "string",
      "default": "grid"
    }
  },
  "render": "file:./render.php"
}