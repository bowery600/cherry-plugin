{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "cherrystone/news-list",
  "version": "1.0.0",
  "title": "News List",
  "category": "cherrystone",
  "icon": "media-document",
  "description": "Editorial list for updates, announcements, press, articles, or communications.",
  "textdomain": "cherrystone-blocks",
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ]
  },
  "attributes": {
    "eyebrow": {
      "type": "string",
      "default": "Communications"
    },
    "heading": {
      "type": "string",
      "default": "Latest updates."
    },
    "lede": {
      "type": "string",
      "default": "Use this section for news, member notes, event recaps, or portfolio announcements."
    },
    "maxItems": {
      "type": "number",
      "default": 0
    },
    "categoryFilter": {
      "type": "string",
      "default": ""
    }
  },
  "render": "file:./render.php"
}