{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "cherrystone/people-grid",
	"version": "1.1.0",
	"title": "People Grid",
	"category": "cherrystone",
	"icon": "groups",
	"description": "Dynamic people grid driven by the Team Members you manage in wp-admin.",
	"textdomain": "cherrystone-blocks",
	"supports": {
		"html": false,
		"align": [ "wide", "full" ]
	},
	"attributes": {
		"eyebrow": {
			"type": "string",
			"default": "People"
		},
		"heading": {
			"type": "string",
			"default": "The people behind the work."
		},
		"lede": {
			"type": "string",
			"default": "Use this grid for leadership, advisors, members, committees, or partner teams."
		},
		"committeeFilter": {
			"type": "string",
			"default": ""
		},
		"maxItems": {
			"type": "number",
			"default": 0
		}
	},
	"render": "file:./render.php"
}
