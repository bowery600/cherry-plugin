{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "cherrystone/resource-cards",
	"version": "1.1.0",
	"title": "Resource Cards",
	"category": "cherrystone",
	"icon": "index-card",
	"description": "Card grid driven by the Member Resources you manage in wp-admin.",
	"textdomain": "cherrystone-blocks",
	"supports": {
		"html": false,
		"align": [ "wide", "full" ]
	},
	"attributes": {
		"eyebrow": {
			"type": "string",
			"default": "Resources"
		},
		"heading": {
			"type": "string",
			"default": "Useful links and next steps."
		},
		"lede": {
			"type": "string",
			"default": "A flexible card grid for documents, programs, benefits, or services."
		},
		"warm": {
			"type": "boolean",
			"default": true
		},
		"maxItems": {
			"type": "number",
			"default": 0
		},
		"tagFilter": {
			"type": "string",
			"default": ""
		},
		"collapseAfter": {
			"type": "number",
			"default": 0
		}
	},
	"render": "file:./render.php"
}
